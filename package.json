{
  "name": "combat-tactics-unlimited",
  "private": true,
  "description": "Local static server for browser preview (ES modules + fetch require HTTP).",
  "scripts": {
    "start": "python tools/serve_dev.py",
    "serve": "python tools/serve_dev.py",
    "serve:node": "npx --yes serve . -l 8080",
    "catalog-assets": "node tools/catalog_assets.mjs",
    "catalog-assets:cleanup": "node tools/catalog_assets.mjs --cleanup --cleanup-include-primary",
    "catalog-assets:cleanup-preview": "node tools/catalog_assets.mjs --cleanup-dry-run --cleanup-include-primary",
    "cleanup-scan": "node tools/librarian_cleanup.mjs --dry-run --include-primary",
    "migrate-maps": "node tools/migrate_maps.mjs",
    "verify-tree-collision": "node js/battle-plane/verifyTreeCollision.mjs",
    "verify-los-building": "node js/battle-plane/verifyLosBuilding.mjs",
    "visual-report": "node tools/catalog_assets.mjs --visual-report",
    "scan-new-arrivals": "node tools/scan_new_arrivals_disk.mjs",
    "smart-catalog": "node tools/smart_catalog.mjs",
    "smart-catalog:unified": "node tools/smart_catalog.mjs --unified-ingest",
    "smart-catalog:reprocess-review": "node tools/smart_catalog.mjs --unified-ingest --reprocess-review",
    "smart-catalog:move-to-assets": "node tools/smart_catalog.mjs",
    "smart-catalog:reference-labels": "node tools/smart_catalog.mjs --reference-labels",
    "smart-catalog:watch": "node tools/smart_catalog.mjs --watch",
    "smart-catalog:dry": "node tools/smart_catalog.mjs --dry-run",
    "generate-ctu": "node tools/generate_ctu_sidecars.mjs",
    "slice-sprites": "node tools/sprite_sheet_slice.mjs",
    "slice-sprites:scan": "node tools/sprite_sheet_slice.mjs scan",
    "slice-16-grid": "node tools/slice_16_grid_deterministic.mjs",
    "extract-sprites-json": "node tools/extract_sprites_from_json.mjs",
    "validate-map-terrain": "node tools/validate_map_catalog_terrain.mjs",
    "asset-pipeline:analyze": "node tools/asset_pipeline_ingest.mjs analyze",
    "asset-pipeline:duplicates": "node tools/asset_pipeline_ingest.mjs duplicates",
    "asset-pipeline:organize": "node tools/asset_pipeline_ingest.mjs organize --dry-run",
    "asset-pipeline:promote-tank-vfx": "node tools/asset_pipeline_ingest.mjs promote-light-tank-vfx",
    "migrate-attached:mapping": "node tools/safe_attached_migration/cli.mjs mapping",
    "migrate-attached:dry-run": "node tools/safe_attached_migration/cli.mjs dry-run",
    "migrate-attached:copy": "node tools/safe_attached_migration/cli.mjs copy",
    "migrate-attached:sprite-animations": "node tools/safe_attached_migration/applySpriteAnimationsIfPresent.mjs",
    "recolor-cyberpunk-gui": "node tools/recolor_cyberpunk_gui.mjs --src \"assets/New_Arrivals/cyberpunk GUI plus more\" --out assets/ui/cyberpunk-tactical",
    "organize-cyberpunk-ui": "node tools/organize_cyberpunk_ui_kit.mjs",
    "extract-cp-windows": "node tools/extract_cp_windows_frames.mjs",
    "build-ui-master": "node tools/build_ui_master.mjs",
    "align-cyberpunk-green-ui": "node tools/align_cyberpunk_green_ui.mjs",
    "unify-ui-assets": "node tools/unify_metal_ui_assets.mjs",
    "cyberpunk-to-military-unified": "node tools/cyberpunk_to_military_unified.mjs",
    "process-craftpix-bonus-cyber": "node tools/process_craftpix_bonus_cyber.mjs",
    "process-combat-frame-cyber": "node tools/process_combat_frame_cyber.mjs"
  },
  "devDependencies": {
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^5.0.0",
    "fs-extra": "^11.3.4",
    "sharp": "^0.34.5"
  }
}
